rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /votes/{uuid} {
      allow read: if true;

      allow create: if request.auth != null
                    && request.auth.uid == uuid
                    && request.resource.data.keys().hasOnly(['vote', 'timestamp', 'name'])
                    && request.resource.data.vote in ['release', 'hold']
                    && (!('name' in request.resource.data) || (request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() <= 50));

      // Only allowed update: adding a comment (comment, name, commentedAt) exactly once
      allow update: if request.auth != null
                    && request.auth.uid == uuid
                    && !('commentedAt' in resource.data)
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['comment', 'name', 'commentedAt'])
                    && request.resource.data.comment is string
                    && request.resource.data.comment.size() > 0
                    && request.resource.data.comment.size() <= 500;

      allow delete: if false;
    }

  }
}
